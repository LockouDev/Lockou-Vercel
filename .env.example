# One code for one password, or multiple codes separated by commas.
ADMIN_ACCESS_CODES=admin-code-here,friend-code-here

# Long random string used to sign the admin session cookie.
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Roblox Open Cloud Data Store access.
ROBLOX_OPEN_CLOUD_API_KEY=replace-with-your-open-cloud-key
ROBLOX_UNIVERSE_ID=replace-with-your-universe-id
ROBLOX_DATASTORE_NAME=replace-with-your-datastore-name

# Optional. Defaults to "global" if omitted.
# ROBLOX_DATASTORE_SCOPE=global
